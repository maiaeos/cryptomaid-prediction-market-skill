# 预测市场套利引擎配置

# === 平台 API 配置 ===

# Limitless (Base 链)
LIMITLESS_API_KEY=your_limitless_api_key_here
LIMITLESS_ACCOUNT_ADDRESS=your_wallet_address

# Polymarket (Polygon 链)
POLYMARKET_RPC=https://polygon-rpc.com
POLYMARKET_PRIVATE_KEY=your_private_key_here
POLYMARKET_FUNDER_ADDRESS=your_funder_address

# Predict.fun (BNB 链)
PREDICT_FUN_API_KEY=your_predict_fun_api_key
PREDICT_FUN_RPC=https://bsc-dataseed.binance.org
PREDICT_FUN_PRIVATE_KEY=your_private_key_here

# === Telegram 配置 ===
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# === OneKey 配置 ===
ONEKEY_ENABLED=true
ONEKEY_BRIDGE_URL=http://localhost:21320

# === Venus 配置 ===
VENUS_ENABLED=false
BSC_RPC=https://bsc-dataseed.binance.org
VENUS_PRIVATE_KEY=your_bsc_private_key

# === 套利参数 ===

# 最小利润阈值 (0.005 = 0.5%)
MIN_PROFIT_PCT=0.005

# 最大单次套利金额 (USDC)
MAX_ARB_SIZE=100

# 监控间隔 (秒)
SCAN_INTERVAL=60

# 总资金限制 (USDC)
TOTAL_BUDGET=500

# 单笔最大仓位 (USDC)
MAX_POSITION_SIZE=150
